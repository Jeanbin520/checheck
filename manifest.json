{
  "manifest_version": 3,
  "name": "佬站助手",
  "version": "1.0.0",
  "description": "一键签到基于 new-api 的公益站点，并辅助 LinuxDO 主题阅读",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "sidePanel",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "佬站助手",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/injector.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://linux.do/*"],
      "js": ["content/linuxdo-reading-helper.js"],
      "run_at": "document_idle"
    }
  ]
}
